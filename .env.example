# MyHome viene pubblicato solo come add-on/container nella rete LAN.
# Per Docker standalone usa preferibilmente l'IP privato stabile di Home Assistant.
HA_URL=http://192.168.1.20:8123
HA_TOKEN=

# Produzione: obbligatorio. Lascia vuoto solo se vuoi che run.sh generi e
# persista i due codici al primo avvio (saranno stampati una volta nei log).
MYHOME_ADMIN_TOKEN=
MYHOME_KIOSK_TOKEN=
MYHOME_AUTH_MODE=required

# Storage locale in sviluppo. Docker Compose lo sovrascrive con /data/db.json.
MYHOME_DB_PATH=backend/data/db.json
# MYHOME_READ_ONLY=true

# Bridge HA: WebSocket con fallback automatico al polling.
# MYHOME_HA_STREAM=poll
# MYHOME_HA_POLL_MS=1500

# Integrazioni opzionali, sempre e solo lato backend.
# OPENWEATHER_API_KEY=
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# NEWS_RSS_URL=https://example.org/feed.xml
# NEWS_RSS_ALLOWED_HOSTS=example.org

# Solo sviluppo: cambia il target del proxy /api di Vite; non è un segreto.
# VITE_BACKEND_URL=http://localhost:3001
